# Sao chép file này thành .env rồi điền giá trị thật (KHÔNG commit .env)

# Chuỗi kết nối MongoDB Atlas (Connect > Drivers > Node.js).
# Nhớ thay <db_password> bằng mật khẩu thật và thêm tên DB "lichlop" trước dấu "?"
MONGODB_URI=mongodb+srv://lichlop:<db_password>@cluster0.xxxxx.mongodb.net/lichlop?retryWrites=true&w=majority

# Tên database (mặc định lichlop nếu bỏ trống)
DB_NAME=lichlop

# Cổng chạy local (host sẽ tự cấp PORT khi deploy)
PORT=3000

# Origin được phép gọi API (trang học sinh). Để * khi đang phát triển.
# Khi deploy thật nên đặt đúng domain trang học sinh, vd: https://hocsinh.example.com
CORS_ORIGIN=*

# Tài khoản giáo viên
TEACHER_USERNAME=gv
TEACHER_PASSWORD=123456
TEACHER_NAME=Thay/Co
